# ══════════════════════════════════════════════
#  Quotex OTC Signal Bot — متغيرات البيئة
#  انسخ هذا الملف وسمّه .env أو أدخله في Railway
# ══════════════════════════════════════════════

# ── Telegram ──────────────────────────────────
TELEGRAM_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ── Quotex ────────────────────────────────────
QUOTEX_EMAIL=your_email@example.com
QUOTEX_PASSWORD=your_quotex_password
QUOTEX_TOKEN=your_quotex_token_here

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── إعدادات السيرفر ───────────────────────────
PORT=3000

# ── قاعدة بيانات الجلسة (Railway فقط) ─────────
# اتركه فارغاً = يُحفظ في نفس مجلد البوت
SESSION_DB_PATH=/data/session_store.db
